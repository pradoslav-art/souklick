modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.build]
args = ["sh", "-c", "pnpm install --frozen-lockfile && pnpm --filter @workspace/souklick run build && pnpm --filter @workspace/api-server run build"]
env = { "NODE_ENV" = "production" }

[deployment.run]
args = ["node", "artifacts/api-server/dist/index.mjs"]
env = { "NODE_ENV" = "production" }

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["psmisc"]

[userenv]

[userenv.shared]
ADMIN_EMAIL = "souklickuae@gmail.com"
